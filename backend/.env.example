ENV=dev
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://royd:royd_dev_pw@postgres:5432/royd

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-in-production-use-at-least-32-chars-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# HEMIS (student SSO)
HEMIS_BASE_URL=https://student.ndki.uz
HEMIS_USE_MOCK=true

# SMTP (MailHog in dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@royd.uz
SMTP_TLS=false

# File storage
STORAGE_DIR=/app/storage/uploads
MAX_UPLOAD_MB=20

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=120
